# Dark Prompt — environment variables.
# Copy to `.env` (or export in your shell / process supervisor) and adjust.
# Lines starting with # are comments and ignored.

# ---------------------------------------------------------------------------
# Core Django
# ---------------------------------------------------------------------------

# 1 = development (DEBUG on, ALLOWED_HOSTS=*, dev-only fallback secret allowed)
# 0 = production (strict checks; must set SECRET_KEY + ALLOWED_HOSTS)
DJANGO_DEBUG=1

# 50+ chars random. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Required when DJANGO_DEBUG=0 — settings.py refuses to boot otherwise.
DJANGO_SECRET_KEY=

# Comma-separated host list. Required when DJANGO_DEBUG=0.
# Example: darkprompt.example.com,www.darkprompt.example.com
DJANGO_ALLOWED_HOSTS=

# Comma-separated trusted origins for CSRF (must include scheme).
# Example: https://darkprompt.example.com,https://www.darkprompt.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# ---------------------------------------------------------------------------
# Cookie + transport security (production)
# ---------------------------------------------------------------------------

# Defaults: 0 in dev, 1 in prod. Override only if you know what you're doing.
DJANGO_SESSION_COOKIE_SECURE=
DJANGO_CSRF_COOKIE_SECURE=

# Set to 1 if a reverse proxy terminates HTTPS and forwards as HTTP +
# X-Forwarded-Proto. Lets request.is_secure() return True.
DJANGO_BEHIND_TLS_PROXY=0

# Force HTTP -> HTTPS redirect at the Django layer (prod only). Default 1.
DJANGO_SECURE_SSL_REDIRECT=1

# HSTS max-age in seconds. 0 disables. Recommend 2592000 (30 days) once you've
# verified HTTPS works end-to-end, then bump to 31536000 (1 year).
DJANGO_SECURE_HSTS_SECONDS=0

# ---------------------------------------------------------------------------
# Email (password-reset + email-verification links)
# ---------------------------------------------------------------------------

# Backend selection:
#   - dev / local:               django.core.mail.backends.console.EmailBackend
#   - prod with SMTP allowed:    django.core.mail.backends.smtp.EmailBackend
#   - prod on Render free tier:  accounts.email_backends.BrevoBackend
#                            or  accounts.email_backends.ResendBackend
#     (Render free tier blocks SMTP egress; Brevo/Resend use HTTPS instead)
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# --- Brevo (HTTPS API, free tier 300/day) ------------------------------
# Sign up at https://brevo.com. Verify a SINGLE sender email (no domain
# needed), then you can send to anyone. Best fit when you don't own a
# domain. Get the key from "SMTP & API" -> "API Keys" in the dashboard.
BREVO_API_KEY=

# --- Resend (HTTPS API, free tier 3000/mo) -----------------------------
# Sign up at https://resend.com. Free tier requires DOMAIN verification
# before you can send to recipients other than your signup email.
# Use only if you have a custom domain.
RESEND_API_KEY=

# Default From address. With BrevoBackend this MUST match a verified sender
# in your Brevo account. With ResendBackend it must be on a verified domain.
DJANGO_DEFAULT_FROM_EMAIL=Dark Prompt <verified@example.com>

# --- SMTP fallback (used only by the smtp.EmailBackend) ---------------
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=25
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=0

# ---------------------------------------------------------------------------
# Local LLM backend (Gradio)
# ---------------------------------------------------------------------------

# Two LLM backends — one for Assembly, one for C. Each conversation is
# stamped at creation with the language it was started in, and the chat
# backend routes prompts to whichever URL matches.
#
# Base URL of the Gradio space hosting the *Assembly* model. Examples:
#   - Kaggle / Colab tunnel: https://0c9b6512f767fc4aa2.gradio.live
#   - HF Space:              https://username-myspace.hf.space
#   - Local dev:             http://127.0.0.1:7860
# Note: gradio.live URLs rotate every few hours. Update this and restart
# the server when your Kaggle notebook reissues a tunnel.
LLM_API_URL=http://127.0.0.1:7860
LLM_API_NAME=/generate

# Base URL of the Gradio space hosting the *C* model. Leave empty to
# disable C-mode (the toggle will be hidden in the UI).
LLM_API_URL_C=
LLM_API_NAME_C=/generate

# Reserved for future use; the gradio_client doesn't currently honour this.
LLM_API_TIMEOUT=120

# Synthetic dollar rate per 1k tokens, used by the chat header meter.
LLM_COST_PER_1K_TOKENS=0.0005

# ---------------------------------------------------------------------------
# Groq (chat-title inference + future AI-agent helpers)
# ---------------------------------------------------------------------------

# Get a free key at https://console.groq.com — it's used to generate a 3-6
# word title for each chat after the first response. Empty key disables
# the feature; titles fall back to a truncation of the first user prompt.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=8

# ---------------------------------------------------------------------------
# CORS for /api/chat/
# ---------------------------------------------------------------------------

# Comma-separated list of exact origins allowed to make CORS requests against
# /api/chat/ (with a Bearer API key). Example:
#   LLM_CORS_ALLOW_ORIGINS=https://app.example.com,https://lab.example.org
# Use "*" only if you know the requests will be non-credentialed.
# Empty / unset → same-origin only.
LLM_CORS_ALLOW_ORIGINS=

# ---------------------------------------------------------------------------
# Code sandbox (Analyse + Compile buttons in the chat code blocks)
# ---------------------------------------------------------------------------

# Optional absolute paths to local toolchains. If unset, the sandbox scans
# $PATH for sensible default names. Set these only if your install is in a
# non-standard place or you want to pin a specific version.
DARK_PROMPT_NASM=
DARK_PROMPT_MASM=
DARK_PROMPT_GCC=
DARK_PROMPT_CLANG=
DARK_PROMPT_PYTHON=
DARK_PROMPT_PWSH=
DARK_PROMPT_BASH=
DARK_PROMPT_GO=
DARK_PROMPT_RUSTC=
